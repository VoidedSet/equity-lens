# Copy to .env and fill keys as needed.
NEWSAPI_KEY=
BING_NEWS_API_KEY=
BING_NEWS_ENDPOINT=https://api.bing.microsoft.com/v7.0/news/search
USER_AGENT=EquityLensNewsBot/1.0 (+contact: team@equitylens.local)

# Optional output path override
OUTPUT_DIR=./output

# Optional graph integration (Neo4j)
GRAPH_ENABLE=true
GRAPH_NEO4J_URI=neo4j://127.0.0.1:7687
GRAPH_NEO4J_USER=neo4j
GRAPH_NEO4J_PASSWORD=
GRAPH_NEO4J_DATABASE=

# Confidence thresholds for graph writes
GRAPH_CONFIDENCE_MIN=0.65
GRAPH_REVIEW_MIN=0.45
